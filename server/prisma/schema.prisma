// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum SubscriptionTier {
  FREE
  BASIC
  PREMIUM
}

enum OperationalExpenseType {
  PREPAID    // User pays all expenses upfront
  POSTPAID   // Renter pays monthly
}

model User {
  id          Int           @id @default(autoincrement())
  email       String        @unique
  password    String
  name        String?
  subscription Subscription?
  OTP         OTP[]
  Renter      Renter[]
  Property    Property[]
  Operator    Operator[]
}

model OTP {
  id            Int                 @id @default(autoincrement())
  code          String
  user          User                @relation(fields: [userId], references: [id], onUpdate: Cascade, onDelete: Cascade)
  userId        Int         
  expiredDate   DateTime
}

model Property {
  id                Int             @id @default(autoincrement())
  propertyName      String
  dueDate           Int
  userId            Int             
  propertyImage     String
  user              User            @relation(fields: [userId], references: [id], onUpdate: Cascade, onDelete: Cascade)
  Operator          Operator[]
  Renter            Renter[]
  Room              Room[]
  operationalSettings OperationalSettings?
}

model Operator {
  id                Int             @id @default(autoincrement())
  operatorName      String
  user              User?            @relation(fields: [userId], references: [id], onUpdate: Cascade, onDelete: SetNull)
  userId            Int?
  propertyId        Int?             @unique
  property          Property?       @relation(fields: [propertyId], references: [id], onUpdate: Cascade, onDelete: SetNull)
}

model Room {
  id                Int             @id @default(autoincrement())
  typeName          String       
  price             Int
  roomImage         String?
  Area              Int
  propertyId        Int
  property          Property        @relation(fields: [propertyId], references: [id], onUpdate: Cascade, onDelete: Cascade)
  totalRooms        Int
  status            String          @default("Available")
  individualRooms   IndividualRoom[]
  renters          Renter[]
}

model IndividualRoom {
  id                Int             @id @default(autoincrement())
  roomNumber        String          
  status            String          @default("Available")
  room              Room            @relation(fields: [roomId], references: [id], onUpdate: Cascade, onDelete: Cascade)
  roomId            Int
  renters           Renter[]
}

model OperationalSettings {
  id                Int                   @id @default(autoincrement())
  propertyId        Int                   @unique
  property          Property              @relation(fields: [propertyId], references: [id], onUpdate: Cascade, onDelete: Cascade)
  electricityType   OperationalExpenseType @default(POSTPAID)
  waterType         OperationalExpenseType @default(POSTPAID)
  internetType      OperationalExpenseType @default(POSTPAID)
  electricityDueDay Int                   @default(1)  // Day of month when payment is due
  waterDueDay      Int                   @default(1)
  internetDueDay   Int                   @default(1)
  // For PREPAID types, store the duration
  electricityDuration Int?                // in months (1, 6, or 12)
  waterDuration      Int?                // in months
  internetDuration   Int?                // in months
  // Fixed monthly costs for POSTPAID
  electricityCost   Int?
  waterCost         Int?
  internetCost      Int?
}

model RenterExpenses {
  id                  Int             @id @default(autoincrement())
  renterId            Int             
  renter              Renter          @relation(fields: [renterId], references: [id], onUpdate: Cascade, onDelete: Cascade)
  maintenanceType     String          // 'OPERATIONAL' or 'MAINTENANCE'
  maintenanceCategory String          // 'Electricity', 'Water', 'Internet', 'Air Conditioning', etc.
  serviceDate         DateTime
  serviceDescription  String?
  servicePrice        Int
  serviceInvoice      String
  lastPaymentDate     DateTime
  isPrepaid           Boolean         @default(false)  // To distinguish between prepaid and postpaid expenses
  durationMonths      Int?            // For prepaid expenses, how many months it covers
  startDate           DateTime?       // For prepaid expenses, when the coverage starts
  endDate             DateTime?       // For prepaid expenses, when the coverage ends
  dueDate             DateTime?       // When the payment is due
  isOverdue           Boolean         @default(false)
  
}

model Renter {
  id                Int                   @id @default(autoincrement())
  user              User                  @relation(fields: [userId], references: [id], onUpdate: Cascade, onDelete: Cascade)
  userId            Int
  renterName        String
  renterEmail       String
  renterPhone       String
  ktpNumber         String                
  joinDate          DateTime
  leaveDate         DateTime
  hasLeaved         Boolean               @default(false)
  room              Room                  @relation(fields: [roomId], references: [id], onUpdate: Cascade, onDelete: Cascade)
  roomId            Int                   // Keep track of room type
  individualRoom    IndividualRoom        @relation(fields: [individualRoomId], references: [id], onUpdate: Cascade, onDelete: Cascade)
  individualRoomId  Int                   // Specific room assignment
  property          Property              @relation(fields: [propertyId], references: [id], onUpdate: Cascade, onDelete: Cascade)
  propertyId        Int
  depositAmount     Int
  RenterExpenses    RenterExpenses[]
  RenterTransaction RenterTransaction[]
}

model RenterTransaction {
  id                Int       @id @default(autoincrement())
  renterId          Int
  renter            Renter    @relation(fields: [renterId], references: [id])
  orderId           String    @unique
  paymentStatus     Boolean   @default(false)
  amount            Int
  createdAt         DateTime  @default(now())
  dueDate           DateTime  // Add this field
  paidAt            DateTime? // Add this field to track when payment was made
  isOverdue         Boolean   @default(false)
  month             Int       // Add this to track which month this payment is for
  year              Int       // Add this to track which year this payment is for
}

model Subscription {
  id          Int             @id @default(autoincrement())
  userId      Int             @unique
  user        User            @relation(fields: [userId], references: [id])
  tier        SubscriptionTier @default(FREE)
  startDate   DateTime        @default(now())
  endDate     DateTime?
  active      Boolean         @default(true)
}


